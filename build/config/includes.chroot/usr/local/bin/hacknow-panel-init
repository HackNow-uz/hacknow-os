#!/bin/bash
# HackNow OS — XFCE panel'ni har user uchun BIR MARTA canonical formatda yaratadi.
# XFCE 4.18 xfconfd skel XML'ni o'qiganda ba'zan default panel'lar qo'shib qo'yadi —
# bu duplikat va noto'g'ri pozitsiyalarga olib keladi. Shu sabab xfconf-query
# orqali to'g'ridan-to'g'ri set qilamiz, xfconfd o'zining canonical formatida yozadi.

FLAG="$HOME/.config/hacknow-panel-initialized"
[ -f "$FLAG" ] && exit 0

# X sessiyaga ulanish kerak
[ -z "$DISPLAY" ] && exit 0

# xfconfd ishga tushishi uchun pauza
sleep 4

# Avval barcha xfce4-panel propertilarini reset
xfconf-query -c xfce4-panel -p / -r -R 2>/dev/null || true
sleep 1

# === PANEL-1 (top horizontal status bar) ===
xfconf-query -c xfce4-panel -p /panels -t int -t int -s 1 -s 2 -a --create
xfconf-query -c xfce4-panel -p /panels/panel-1/position --type string --set "p=2;x=0;y=0" --create
xfconf-query -c xfce4-panel -p /panels/panel-1/length --type uint --set 100 --create
xfconf-query -c xfce4-panel -p /panels/panel-1/size --type uint --set 32 --create
xfconf-query -c xfce4-panel -p /panels/panel-1/icon-size --type uint --set 18 --create
xfconf-query -c xfce4-panel -p /panels/panel-1/position-locked --type bool --set true --create
xfconf-query -c xfce4-panel -p /panels/panel-1/background-style --type uint --set 1 --create
xfconf-query -c xfce4-panel -p /panels/panel-1/background-rgba \
    -t double -t double -t double -t double \
    -s 0.039 -s 0.039 -s 0.039 -s 0.96 -a --create
xfconf-query -c xfce4-panel -p /panels/panel-1/plugin-ids \
    -t int -t int -t int -t int -t int -t int -t int -t int -t int -t int \
    -s 1 -s 2 -s 3 -s 4 -s 5 -s 6 -s 14 -s 15 -s 7 -s 8 -a --create

# Plugins
xfconf-query -c xfce4-panel -p /plugins/plugin-1 --type string --set "applicationsmenu" --create
xfconf-query -c xfce4-panel -p /plugins/plugin-1/button-icon --type string --set "/usr/share/pixmaps/hacknow-logo.png" --create
xfconf-query -c xfce4-panel -p /plugins/plugin-1/show-button-icon --type bool --set true --create
xfconf-query -c xfce4-panel -p /plugins/plugin-1/show-button-title --type bool --set false --create

xfconf-query -c xfce4-panel -p /plugins/plugin-2 --type string --set "separator" --create
xfconf-query -c xfce4-panel -p /plugins/plugin-2/style --type uint --set 3 --create

xfconf-query -c xfce4-panel -p /plugins/plugin-3 --type string --set "tasklist" --create
xfconf-query -c xfce4-panel -p /plugins/plugin-3/flat-buttons --type bool --set true --create
xfconf-query -c xfce4-panel -p /plugins/plugin-3/show-labels --type bool --set true --create
xfconf-query -c xfce4-panel -p /plugins/plugin-3/show-handle --type bool --set false --create
xfconf-query -c xfce4-panel -p /plugins/plugin-3/grouping --type uint --set 0 --create
xfconf-query -c xfce4-panel -p /plugins/plugin-3/show-tooltips --type bool --set true --create

xfconf-query -c xfce4-panel -p /plugins/plugin-4 --type string --set "separator" --create
xfconf-query -c xfce4-panel -p /plugins/plugin-4/expand --type bool --set true --create
xfconf-query -c xfce4-panel -p /plugins/plugin-4/style --type uint --set 0 --create

xfconf-query -c xfce4-panel -p /plugins/plugin-5 --type string --set "systray" --create
xfconf-query -c xfce4-panel -p /plugins/plugin-5/size-max --type uint --set 18 --create
xfconf-query -c xfce4-panel -p /plugins/plugin-5/square-icons --type bool --set true --create
xfconf-query -c xfce4-panel -p /plugins/plugin-5/symbolic-icons --type bool --set true --create

xfconf-query -c xfce4-panel -p /plugins/plugin-6 --type string --set "notification-plugin" --create

xfconf-query -c xfce4-panel -p /plugins/plugin-7 --type string --set "clock" --create
xfconf-query -c xfce4-panel -p /plugins/plugin-7/digital-format --type string --set "%H:%M  %a %d %b" --create
xfconf-query -c xfce4-panel -p /plugins/plugin-7/mode --type uint --set 2 --create

xfconf-query -c xfce4-panel -p /plugins/plugin-8 --type string --set "actions" --create
xfconf-query -c xfce4-panel -p /plugins/plugin-8/items \
    -t string -t string -t string -t string \
    -s "+lock-screen" -s "+separator" -s "+suspend" -s "+shutdown" -a --create

xfconf-query -c xfce4-panel -p /plugins/plugin-14 --type string --set "pulseaudio" --create
xfconf-query -c xfce4-panel -p /plugins/plugin-15 --type string --set "xkb" --create
xfconf-query -c xfce4-panel -p /plugins/plugin-15/display-type --type uint --set 2 --create
xfconf-query -c xfce4-panel -p /plugins/plugin-15/display-name --type uint --set 1 --create

# === PANEL-2 (bottom dock with launchers) ===
xfconf-query -c xfce4-panel -p /panels/panel-2/position --type string --set "p=10;x=640;y=800" --create
xfconf-query -c xfce4-panel -p /panels/panel-2/length --type uint --set 1 --create
xfconf-query -c xfce4-panel -p /panels/panel-2/length-adjust --type bool --set true --create
xfconf-query -c xfce4-panel -p /panels/panel-2/size --type uint --set 48 --create
xfconf-query -c xfce4-panel -p /panels/panel-2/icon-size --type uint --set 36 --create
xfconf-query -c xfce4-panel -p /panels/panel-2/position-locked --type bool --set true --create
xfconf-query -c xfce4-panel -p /panels/panel-2/autohide-behavior --type uint --set 1 --create
xfconf-query -c xfce4-panel -p /panels/panel-2/background-style --type uint --set 1 --create
xfconf-query -c xfce4-panel -p /panels/panel-2/background-rgba \
    -t double -t double -t double -t double \
    -s 0.039 -s 0.039 -s 0.039 -s 0.75 -a --create
# Live session aniqlash — agar live bo'lsa dock'ga installer qo'shamiz
IS_LIVE=0
if grep -q "boot=live" /proc/cmdline 2>/dev/null; then
    IS_LIVE=1
fi

if [ "$IS_LIVE" = "1" ]; then
    # Live'da: 8 launcher (oxirgisi installer)
    xfconf-query -c xfce4-panel -p /panels/panel-2/plugin-ids \
        -t int -t int -t int -t int -t int -t int -t int -t int \
        -s 20 -s 21 -s 22 -s 23 -s 24 -s 25 -s 26 -s 27 -a --create
else
    # Installed'da: 7 launcher (installer kerak emas)
    xfconf-query -c xfce4-panel -p /panels/panel-2/plugin-ids \
        -t int -t int -t int -t int -t int -t int -t int \
        -s 20 -s 21 -s 22 -s 23 -s 24 -s 25 -s 26 -a --create
fi

# Launcher'lar (Panel-2 dock)
add_launcher() {
    local id=$1 desktop=$2
    xfconf-query -c xfce4-panel -p /plugins/plugin-$id --type string --set "launcher" --create
    xfconf-query -c xfce4-panel -p /plugins/plugin-$id/items -t string -s "$desktop" -a --create
}

add_launcher 20 "xfce4-terminal.desktop"
add_launcher 21 "thunar.desktop"
add_launcher 22 "firefox-esr.desktop"
add_launcher 23 "hacknow-nmap.desktop"
add_launcher 24 "hacknow-sqlmap.desktop"
add_launcher 25 "hacknow-hydra.desktop"
add_launcher 26 "hacknow-wireshark.desktop"

# Live session'da installer launcher qo'shamiz + Desktop'ga ikon
if [ "$IS_LIVE" = "1" ]; then
    add_launcher 27 "install-hacknow.desktop"
    mkdir -p "$HOME/Desktop"
    cp /usr/share/applications/install-hacknow.desktop "$HOME/Desktop/" 2>/dev/null && \
        chmod +x "$HOME/Desktop/install-hacknow.desktop"
fi

# Icon theme — HackNow-Tools
xfconf-query -c xsettings -p /Net/IconThemeName --type string --set "HackNow-Tools" --create

# Panel'ni qayta yuklash
# Panel restart — boot vaqtida "--restart" conflict berishi mumkin, shu sabab kill+start
pkill -9 xfce4-panel 2>/dev/null
sleep 1
setsid nohup xfce4-panel >/dev/null 2>&1 < /dev/null &

# Flag yaratish — qayta ishlamasin
touch "$FLAG"
echo "[HackNow OS] Panel canonical formatda inicializatsiya qilindi"
