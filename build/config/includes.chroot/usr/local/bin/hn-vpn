#!/bin/bash
# hn-vpn — HackNow VPN ulanish
# Usage: hn-vpn connect|disconnect|status

VERSION="0.1.0"
CONFIG_DIR="$HOME/.config/hacknow"
VPN_DIR="$CONFIG_DIR/vpn"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

case "${1:-}" in
    connect)
        CONFIG="${2:-$VPN_DIR/hacknow.ovpn}"
        if [ ! -f "$CONFIG" ]; then
            echo -e "${RED}[!] VPN config topilmadi: $CONFIG${NC}"
            echo "Avval lab'ga ulaning: hn-lab-connect start <lab-id>"
            exit 1
        fi
        echo -e "${YELLOW}[*] VPN ulanmoqda...${NC}"
        sudo openvpn --config "$CONFIG" --daemon --log /tmp/hn-vpn.log
        sleep 3
        if pgrep -x openvpn >/dev/null; then
            echo -e "${GREEN}[✓] VPN ulandi!${NC}"
            IP=$(ip addr show tun0 2>/dev/null | grep 'inet ' | awk '{print $2}')
            echo -e "  Tun0 IP: ${CYAN}${IP:-N/A}${NC}"
        else
            echo -e "${RED}[!] VPN ulanmadi. Log: /tmp/hn-vpn.log${NC}"
        fi
        ;;
    disconnect)
        sudo killall openvpn 2>/dev/null
        echo -e "${GREEN}[✓] VPN uzildi.${NC}"
        ;;
    status)
        if pgrep -x openvpn >/dev/null; then
            IP=$(ip addr show tun0 2>/dev/null | grep 'inet ' | awk '{print $2}')
            echo -e "${GREEN}[✓] VPN faol${NC} — tun0: ${IP:-N/A}"
        else
            echo -e "${YELLOW}[*] VPN o'chirilgan${NC}"
        fi
        ;;
    *)
        echo "Foydalanish: hn-vpn [connect|disconnect|status] [config-fayl]"
        ;;
esac
