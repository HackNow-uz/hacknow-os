configuration {
    modi: "drun,run,window,filebrowser";
    show-icons: true;
    icon-theme: "Papirus-Dark";
    display-drun: " Apps";
    display-run: " Run";
    display-window: " Window";
    display-filebrowser: " Files";
    drun-display-format: "{name}";
    font: "Hack Nerd Font 11";
}

@theme "hacknow"
