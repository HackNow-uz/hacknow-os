gtk-theme-name="HackNow-Dark"
gtk-icon-theme-name="Papirus-Dark"
gtk-cursor-theme-name="Bibata-Modern-Classic"
gtk-cursor-theme-size=24
gtk-font-name="Noto Sans 10"
gtk-menu-images=1
gtk-button-images=1
gtk-toolbar-style=GTK_TOOLBAR_BOTH

# HackNow OS — Custom GTK2 colors
gtk-color-scheme="selected_bg_color:#FF1744\nselected_fg_color:#ffffff\nlink_color:#FF1744"
