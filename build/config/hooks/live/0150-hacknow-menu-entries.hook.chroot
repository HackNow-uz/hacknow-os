make_entry nikto "Nikto" "Web server scanner" "X-HackNow-Web" "kali-nikto" "Web server skaneri"
make_entry dirb "Dirb" "Web directory brute-forcer" "X-HackNow-Web" "kali-dirb" "Web katalog qidiruvchisi"
make_entry wfuzz "Wfuzz" "Web fuzzer" "X-HackNow-Web" "kali-wfuzz" "Web fazzeri"
