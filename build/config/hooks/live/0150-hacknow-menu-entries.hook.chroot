# ═══════════════════════════════════════
# GUI TOOL'LARGA KATEGORIYA QO'SHISH
# ═══════════════════════════════════════
add_cat() {
    local file="$1" cat="$2"
    [ -f "$APPS/$file" ] || return 0
    if ! grep -q "$cat" "$APPS/$file" 2>/dev/null; then
        sed -i "s|^Categories=\(.*\)|Categories=\1;$cat|" "$APPS/$file" 2>/dev/null || true
    fi
}

add_cat "wireshark.desktop" "X-HackNow-Recon"
add_cat "org.wireshark.Wireshark.desktop" "X-HackNow-Recon"
add_cat "ettercap.desktop" "X-HackNow-Network"
add_cat "org.keepassxc.KeePassXC.desktop" "X-HackNow-Passwords"
add_cat "gimp.desktop" "X-HackNow-CTF"
add_cat "audacity.desktop" "X-HackNow-CTF"

echo "[HackNow OS] $COUNT ta tool menu'ga qo'shildi"
