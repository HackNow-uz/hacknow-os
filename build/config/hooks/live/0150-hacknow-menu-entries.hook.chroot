#!/bin/sh
# HackNow OS — Pentest tool'lar uchun .desktop fayllar yaratish
# Har bir CLI tool'ni XFCE menu'da kategoriyalarga joylashtiradi
set -e

echo "[HackNow OS] Pentest tool menu yozuvlari yaratilmoqda..."

APPS="/usr/share/applications"
COUNT=0

# make_entry cmd name comment category icon comment_uz
make_entry() {
    local cmd="$1" name="$2" comment="$3" cat="$4" icon="${5:-utilities-terminal}" comment_uz="$6"
    command -v "$cmd" >/dev/null 2>&1 || return 0
    [ -f "$APPS/hacknow-${cmd}.desktop" ] && return 0

    cat > "$APPS/hacknow-${cmd}.desktop" << DESKTOP
[Desktop Entry]
Type=Application
Name=$name
Comment=$comment
Comment[uz]=${comment_uz:-$comment}
Exec=xfce4-terminal -T "$name" -e "hn-run $cmd"
Icon=$icon
Terminal=false
Categories=$cat;
StartupNotify=false
DESKTOP
    COUNT=$((COUNT + 1))
}

# ═══════════════════════════════════════
# RECONNAISSANCE
# ═══════════════════════════════════════
make_entry nmap "Nmap" "Network scanner" "X-HackNow-Recon" "kali-nmap" "Tarmoq skaneri"
make_entry masscan "Masscan" "Fast port scanner" "X-HackNow-Recon" "kali-masscan" "Tezkor port skaneri"
make_entry netdiscover "Netdiscover" "ARP reconnaissance" "X-HackNow-Recon" "kali-netdiscover" "ARP razvedkasi"
make_entry zmap "Zmap" "Internet-wide scanner" "X-HackNow-Recon" "" "Internet skaneri"
make_entry dnsrecon "DNSRecon" "DNS enumeration" "X-HackNow-Recon" "kali-dnsrecon" "DNS sanab chiqish"
make_entry dnsenum "DNSenum" "DNS enumeration" "X-HackNow-Recon" "kali-dnsenum" "DNS sanab chiqish"
make_entry fierce "Fierce" "DNS reconnaissance" "X-HackNow-Recon" "kali-fierce" "DNS razvedkasi"
make_entry fping "Fping" "Fast ping sweep" "X-HackNow-Recon" "kali-fping" "Tezkor ping tekshiruvi"
make_entry smbmap "SMBMap" "SMB share enumeration" "X-HackNow-Recon" "kali-smbmap" "SMB ulushlarni sanash"
make_entry nbtscan "NBTScan" "NetBIOS scanner" "X-HackNow-Recon" "kali-nbtscan" "NetBIOS skaneri"
make_entry onesixtyone "OneSixtyOne" "SNMP scanner" "X-HackNow-Recon" "kali-onesixtyone" "SNMP skaneri"
make_entry recon-ng "Recon-ng" "OSINT framework" "X-HackNow-Recon" "kali-recon-ng" "OSINT platformasi"

