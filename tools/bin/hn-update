#!/bin/bash
# hn-update — HackNow OS yangilash
# Usage: hn-update [--tools|--system|--all]
set -u

VERSION="0.1.0"
USER_HOME="${HOME:-/home/$(whoami)}"
GO_BIN="${GOPATH:-$USER_HOME/go}/bin"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

echo -e "${CYAN}"
echo "  HackNow OS Update v${VERSION}"
echo -e "${NC}"

MODE="${1:---all}"

update_system() {
    echo -e "${YELLOW}[1/3] Tizim yangilanmoqda...${NC}"
    sudo apt update
    sudo apt upgrade -y
    sudo apt autoremove -y
    echo -e "${GREEN}[✓] Tizim yangilandi.${NC}"
}

update_tools() {
    echo -e "${YELLOW}[2/3] Pentesting toollar yangilanmoqda...${NC}"

    # pipx tools
    echo "  -> Python toollar..."
    pipx upgrade-all 2>/dev/null || true

    # Go tools
    if command -v go &>/dev/null; then
        echo "  -> Go toollar..."
        GO_TOOLS=(
            "github.com/projectdiscovery/nuclei/v3/cmd/nuclei@latest"
            "github.com/projectdiscovery/subfinder/v2/cmd/subfinder@latest"
            "github.com/projectdiscovery/httpx/cmd/httpx@latest"
            "github.com/ffuf/ffuf/v2@latest"
        )
        for tool in "${GO_TOOLS[@]}"; do
            go install "$tool" 2>/dev/null || true
        done
        # ~/go/bin sudo bilan root home'ga ishora qiladi — to'liq yo'l ishlatamiz
        if [ -d "$GO_BIN" ]; then
            sudo cp -f "$GO_BIN"/* /usr/local/bin/ 2>/dev/null || true
        fi
    fi

    # Metasploit
    if command -v msfupdate &>/dev/null; then
        echo "  -> Metasploit..."
        sudo msfupdate 2>/dev/null || true
    fi

    echo -e "${GREEN}[✓] Toollar yangilandi.${NC}"
}

update_hacknow() {
    echo -e "${YELLOW}[3/3] HackNow toollar yangilanmoqda...${NC}"

    if [ -d /opt/hacknow-tools/.git ]; then
        # Sudo bilan papkaga kirib, sudo bilan pull qilamiz — ownership drift'siz
        sudo sh -c 'cd /opt/hacknow-tools && git pull' || true
    fi

    echo -e "${GREEN}[✓] HackNow toollar yangilandi.${NC}"
}

case "$MODE" in
    --system)  update_system ;;
    --tools)   update_tools ;;
    --hacknow) update_hacknow ;;
    --all)
        update_system
        update_tools
        update_hacknow
        ;;
    *)
        echo "Foydalanish: hn-update [--system|--tools|--hacknow|--all]"
        ;;
esac

echo ""
echo -e "${GREEN}Yangilash tugadi!${NC}"
